<Page x:Class="LLMChat.Views.Pages.DataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LLMChat.Views.Pages"
      mc:Ignorable="d" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DataPage"
      d:DataContext="{d:DesignInstance local:DataPage,
                                     IsDesignTimeCreatable=False}"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      >

    <StackPanel Margin="32,24,32,32">
        <ui:Card Padding="16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="网络配置" FontSize="12" FontWeight="Bold"  Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <ui:TextBox x:Name="IpTextBox" Text="127.0.0.1" Width="140" TextChanged="IpTextBox_TextChanged" />
                        <TextBlock Text=":" VerticalAlignment="Bottom" Margin="4,0,4,8" FontSize="18" FontWeight="Bold" />
                        <ui:TextBox x:Name="PortTextBox" Text="8080" Width="100" TextChanged="PortTextBox_TextChanged"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="24,0,0,0">
                    <ui:Button x:Name="StartButton" Icon="Play24" Content="启动" Appearance="Success" Click="StartButton_Click" Width="90" Margin="0,0,0,4"/>

                    <!--<UniformGrid Columns="1" Rows="2">
                        <ui:Button x:Name="StopButton" Icon="Stop24" Content="停止" Appearance="Secondary" IsEnabled="False" Click="StopButton_Click" Width="90"/>
                    </UniformGrid>-->
                </StackPanel>

                <Rectangle Grid.Column="2" Width="1"  Margin="16,4" HorizontalAlignment="Center"/>

                <Grid Grid.Column="3" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
     
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                            <Ellipse x:Name="StatusIndicator" Width="8" Height="8" Fill="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" />
                            <TextBlock x:Name="StatusText" Text="未运行" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="AddressText" Text="ws://127.0.0.1:8080" Margin="12,0,0,0" VerticalAlignment="Bottom" 
                               FontSize="11"  FontFamily="Consolas"/>
                        </StackPanel>

                        <UniformGrid Columns="2" Rows="1" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="People24" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="连接数:" FontSize="12" />
                                <TextBlock x:Name="ClientCountText" Text="0" Margin="4,0,0,0" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Timer24" FontSize="12" Margin="0,0,6,0" />
                                <TextBlock Text="运行时:" FontSize="12" />
                                <TextBlock x:Name="UptimeText" Text="00:00:00" Margin="4,0,0,0" FontWeight="SemiBold" FontFamily="Consolas"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Grid>
            </Grid>
        </ui:Card>
        <!-- Real-time Data -->
        <ui:Card Margin="0,0,0,16">
            <Border Padding="16">
                <StackPanel>
                    <TextBlock Text="实时监控" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <Grid VerticalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="12" Background="{DynamicResource ControlAltFillColorSecondaryBrush}" CornerRadius="8" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="风扇转速" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock x:Name="FanSpeedValue" Text="{Binding ViewModel.FanSpeed}" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text=" RPM" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,4" />
                                </StackPanel>
                                <ProgressBar x:Name="FanSpeedProgress" Height="3" Maximum="5000" Value="0" Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="12" Background="{DynamicResource ControlAltFillColorSecondaryBrush}" CornerRadius="8" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="温度" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock x:Name="TempValue" Text="--" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text=" °C" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Bottom" Margin="4,0,0,4" />
                                </StackPanel>
                                <ProgressBar Height="3" Value="45" Background="{DynamicResource ControlAltFillColorTertiaryBrush}" Foreground="{DynamicResource PaletteWarningBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="12" Background="{DynamicResource ControlAltFillColorSecondaryBrush}" CornerRadius="8" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="电源状态" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                <StackPanel VerticalAlignment="Center" Margin="0,4,0,0">
                                    <ui:Badge x:Name="PowerStatusBadge" Content="正常运行" Appearance="Success" HorizontalAlignment="Left" Padding="8,2" />
                                    <TextBlock Text="稳定供电中" FontSize="11" Margin="0,8,0,0" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </ui:Card>

        <ui:Card>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="消息控制" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="向服务器发送自定义指令包" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:Button 
                Grid.Column="1"
                Content="📨 发送指令" 
                Padding="20,8"
                Click="SendMessageButton_Click"
                Appearance="Primary" />
            </Grid>
        </ui:Card>
    </StackPanel>
</Page>