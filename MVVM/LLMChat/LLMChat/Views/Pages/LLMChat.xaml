<Page x:Class="LLMChat.Views.Pages.LLMChat"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LLMChat.Views.Pages"
      xmlns:models="clr-namespace:LLMChat.Models.Dtos"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      d:DataContext="{d:DesignInstance local:LLMChat, IsDesignTimeCreatable=False}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LLMChat">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <ui:Button Appearance="Transparent"
            ToolTip="重新生成"
                       HorizontalAlignment="Right"
                       BorderThickness="0"
            >
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="ArrowCounterclockwise24" />
                </StackPanel>
            </ui:Button>
        </Grid>

        <!-- 不再用外层 ScrollViewer 包裹整个区域，让 ListBox 自己处理滚动 -->
        <ui:Card Grid.Row="1" VerticalAlignment="Stretch" Padding="0" MaxHeight="500">
            <ListBox x:Name="ChatListBox" 
                     ItemsSource="{Binding ViewModel.Messages}" 
                     Background="#F5F5F5"
                     BorderThickness="0"
                     VerticalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ChatMessage}">
                        <Grid Margin="15,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Bubble" 
                                    MaxWidth="700" 
                                    Padding="12,8" 
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock x:Name="LoadingText"
                                       Text="{Binding Content}" 
                                       TextWrapping="Wrap"
                                       FontSize="16">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard Name="LoadingStoryboard">
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <ObjectAnimationUsingKeyFrames 
                                    Storyboard.TargetProperty="Text" 
                                    Duration="0:0:1.5">
                                                                        <DiscreteObjectKeyFrame Value="." KeyTime="0:0:0" />
                                                                        <DiscreteObjectKeyFrame Value=".." KeyTime="0:0:0.5" />
                                                                        <DiscreteObjectKeyFrame Value="..." KeyTime="0:0:1.0" />
                                                                    </ObjectAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="LoadingStoryboard" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ui:TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" 
                                                 FontSize="10" 
                                                 Opacity="0.5" 
                                                 HorizontalAlignment="Right" 
                                                 Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Role}" Value="User">
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Bubble" Property="Background" Value="#5B9BD5" />
                                <Setter TargetName="Bubble" Property="CornerRadius" Value="15,15,2,15" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Role}" Value="AI">
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="Bubble" Property="Background" Value="#F3F3F3" />
                                <Setter TargetName="Bubble" Property="CornerRadius" Value="15,15,15,2" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ui:Card>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" Margin="0,0,10,0"  Width="120" ItemsSource="{Binding ViewModel.Models}" 
              SelectedItem="{Binding ViewModel.SelectedModel}" />
            <ui:TextBox Grid.Column="1"
                       x:Name="InputBox"
                       PlaceholderText="输入问题，按 Enter 发送 (Shift+Enter 换行)..."
                       Text="{Binding ViewModel.InputText, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True"
                       MaxHeight="100"
                       VerticalScrollBarVisibility="Auto">
                <ui:TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding ViewModel.SendMessageCommand}" />
                </ui:TextBox.InputBindings>
            </ui:TextBox>

            <ui:Button Grid.Column="2" 
                       Content="发送" 
                       Icon="Send24" 
                       Appearance="Primary" 
                       Command="{Binding ViewModel.SendMessageCommand}"
                       Margin="10,0,0,0" 
                       VerticalAlignment="Bottom" />
        </Grid>
    </Grid>
</Page>