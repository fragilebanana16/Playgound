<Page
    x:Class="MediaHub.Music.Views.MusicHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid
        x:Name="RootGrid"
        Margin="24"
        Focusable="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="AUTO" />
            <RowDefinition Height="AUTO" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:Card
            Grid.Row="0"
            Margin="0,0,0,20"
            Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center">
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="24"
                        FontWeight="Bold"
                        Text="Fav" />
                    <TextBlock
                        Margin="0,0,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="All Created" />

                    <StackPanel Orientation="Horizontal">
                        <ui:Button
                            Appearance="Primary"
                            Command="{Binding ViewModel.PlayAllCommand}"
                            Content="PlayAll"
                            Icon="Play24" />
                        <ui:Button
                            Appearance="Secondary"
                            Content="Download"
                            Icon="ArrowDownload24" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ui:Card>
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Orientation="Horizontal">

            <ui:Button
                Width="auto"
                Margin="5"
                Padding="5"
                HorizontalAlignment="Center"
                Command="{Binding PlayAllCommand}"
                ToolTip="PlayAll">
                <StackPanel Orientation="Horizontal">
                    <Separator Margin="2" />
                    <ui:TextBlock Text="PlayAll" />
                </StackPanel>
            </ui:Button>

            <ui:Button
                Width="auto"
                Margin="5"
                Padding="5"
                HorizontalAlignment="Center"
                Command="{Binding ShufflePlayCommand}"
                ToolTip="Random">
                <StackPanel Orientation="Horizontal">
                    <Separator Margin="2" />
                    <ui:TextBlock Text="Random" />
                </StackPanel>
            </ui:Button>
        </StackPanel>
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Orientation="Horizontal">

            <!--  Sort ComboBox  -->

            <ComboBox
                Width="40"
                Height="35"
                Margin="0,0,5,0"
                HorizontalContentAlignment="Left"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding ViewModel.SortOptions}"
                SelectedItem="{Binding ViewModel.SelectedSortOption, Mode=TwoWay}"
                ToolTip="{Binding ViewModel.SortRuleText}" />


            <ui:Button
                Width="auto"
                Margin="0,0,5,0"
                BorderThickness="0"
                Command="{Binding ViewModel.SearchButtonClickCommand}"
                ToolTip="Search">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <Separator Margin="2" />

                    <TextBox
                        x:Name="SearchTextBox"
                        Width="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="#F3F3F3"
                        BorderBrush="#E5E5E5"
                        BorderThickness="1"
                        FocusVisualStyle="{x:Null}"
                        FontSize="14"
                        FontWeight="Normal"
                        MaxLength="20"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border
                                                x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                                <ScrollViewer
                                                    x:Name="PART_ContentHost"
                                                    Margin="8,4"
                                                    VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter TargetName="border" Property="BorderBrush" Value="#E5E5E5" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewModel.IsSearchExpanded}" Value="True">
                                        <Setter Property="FocusManager.FocusedElement" Value="{Binding RelativeSource={RelativeSource Self}}" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Width"
                                                        To="150"
                                                        Duration="0:0:0.25">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Width"
                                                        To="0"
                                                        Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseIn" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>
            </ui:Button>
            <!--  Song Count Display  -->

            <StackPanel
                MinWidth="80"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <ui:TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    Opacity="0.7"
                    Text="Total" />
                <ui:TextBlock
                    Margin="2,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Text="{Binding SongCount}" />
                <ui:TextBlock
                    VerticalAlignment="Center"
                    FontSize="14"
                    Opacity="0.7"
                    Text="Songs" />
            </StackPanel>


        </StackPanel>
        <!--  List  -->
        <ui:ListView
            Grid.Row="2"
            Padding="0,0,8,0"
            ItemsSource="{Binding ViewModel.FilteredPlaylist}"
            SelectedItem="{Binding ViewModel.CurrentPlaylistItem, Mode=TwoWay}"
            SelectionMode="Single"
            VirtualizingStackPanel.CacheLength="1"
            VirtualizingStackPanel.CacheLengthUnit="Item"
            VirtualizingStackPanel.IsVirtualizing="True"
            VirtualizingStackPanel.ScrollUnit="Pixel"
            VirtualizingStackPanel.VirtualizationMode="Recycling">
            <!--  helper:PlaylistInteractionBehavior.IsEnabled="True"  -->
            <!--  Menu  -->
            <ui:ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Add to" ItemsSource="{Binding PlacementTarget.DataContext.ViewModel.AllPlaylists, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                        <MenuItem.ItemContainerStyle>
                            <Style TargetType="MenuItem">
                                <Setter Property="Header" Value="{Binding Name}" />
                            </Style>
                        </MenuItem.ItemContainerStyle>
                    </MenuItem>
                    <MenuItem
                        Command="{Binding PlayNextCommand}"
                        CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                        Header="Play Next" />
                    <Separator Margin="2" />
                    <MenuItem
                        Command="{Binding DeleteSelectedSongCommand}"
                        CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                        Header="Delete" />
                </ContextMenu>
            </ui:ListView.ContextMenu>
            <ui:ListView.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <!--  Optimize virtualization performance settings  -->
                    <Setter Property="Padding" Value="5,10" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border
                                    x:Name="ItemBorder"
                                    Margin="0,0,15,0"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>

                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#40808080" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter Property="Background" Value="Transparent" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#40808080" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ui:ListView.ItemContainerStyle>
            <ui:ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <!--  Album cover thumbnail  -->
                        <Border
                            Grid.Column="0"
                            Width="40"
                            Height="40"
                            Margin="0,0,8,0"
                            Background="#1AFFFFFF"
                            CornerRadius="8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <!--  Show default icon when album cover is empty  -->
                                        <DataTrigger Binding="{Binding ., Converter={StaticResource AlbumArtConverter}}" Value="{x:Null}">
                                            <Setter Property="Background" Value="#33FFFFFF" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <!--  Actual album cover  -->
                                <Image Source="{Binding ., Converter={StaticResource AlbumArtConverter}}" Stretch="Fill">
                                    <Image.Clip>
                                        <RectangleGeometry
                                            RadiusX="8"
                                            RadiusY="8"
                                            Rect="0,0,39,39" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>

                        <!--  Song Information  -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <ui:TextBlock
                                Margin="0,0,0,2"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="{Binding Title}" />

                            <ui:TextBlock
                                FontSize="12"
                                Opacity="0.7"
                                Text="{Binding Artist}" />

                        </StackPanel>
                        <!--  Album Information  -->
                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Separator Margin="5,0" />
                            <ui:TextBlock
                                Width="300"
                                FontSize="12"
                                Text="{Binding Album}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <!--  Song Duration and Quality Icon  -->
                        <StackPanel
                            Grid.Column="3"
                            Margin="0,0,25,0"
                            VerticalAlignment="Center">
                            <ui:TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding TotalTimeText}" />
                            <!--<Helper:QualityLevelControl QualityLevel="{Binding QualityLevel}"></Helper:QualityLevelControl>-->
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ui:ListView.ItemTemplate>
        </ui:ListView>
    </Grid>
</Page>
